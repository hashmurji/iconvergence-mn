{
  "version": 2,
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/onedrive.js": { "maxDuration": 60 },
    "api/clientdetail.js": { "maxDuration": 60 },
    "api/dashboardstats.js": { "maxDuration": 30 },
    "api/auth0users.js": { "maxDuration": 30 }
  }
}
